"""Generated Qwen3-ASR audio tower frame scaffold."""

from __future__ import annotations

from torch2vk.runtime.logical import LogicalTensor
from torch2vk.runtime.session import RuntimeSession
from torch2vk.export.lowering import resolve_shader_symbol
from torch2vk.export.shaders import (
    ADD_F32,
    ADD_POSITION_F32,
    COMPACT_AFTER_CNN_F32,
    CONV2D_GELU_F32,
    CONV_OUT_F32,
    CU_SEQLENS_U32,
    ENCODER_ATTENTION_F32,
    LAYER_NORM_F32,
    LINEAR_F32,
    LINEAR_GELU_F32,
    PAD_FEATURE_F32,
)

from models.generated_qwen3_asr._frame import Qwen3ASRTorchOp, qwen3_asr_frame
from models.generated_qwen3_asr.tensors.audio_tower import GeneratedQwen3AsrAudioTowerTensors
from models.generated_qwen3_asr.tensors.audio_tower_layer import (
    GeneratedQwen3AsrAudioEncoderLayerTensors,
)


AUDIO_TOWER_TORCH_OPS = (
{% for step in audio_tower_ops %}
    Qwen3ASRTorchOp(
        {{ step.target|pyrepr }},
        {{ step.inputs|pyrepr }},
        {{ step.outputs|pyrepr }},
        {{ step.note|pyrepr }},
    ),
{% endfor %}
)

AUDIO_ENCODER_LAYER_TORCH_OPS = (
{% for step in audio_layer_ops %}
    Qwen3ASRTorchOp(
        {{ step.target|pyrepr }},
        {{ step.inputs|pyrepr }},
        {{ step.outputs|pyrepr }},
        {{ step.note|pyrepr }},
    ),
{% endfor %}
)


def run_generated_qwen3_asr_audio_tower(
    rt: RuntimeSession,
    tensors: GeneratedQwen3AsrAudioTowerTensors,
    *,
    pytorch_compare: bool = True,
    max_ops: int | None = None,
) -> LogicalTensor:
    frame_scope = qwen3_asr_frame(
        rt,
        "generated_qwen3_asr.audio_tower",
        pytorch_compare=pytorch_compare,
        pytorch_model_submodule="thinker.audio_tower",
    )
    with frame_scope:
        env = _audio_tower_env(tensors)
        selected_ops = AUDIO_TOWER_TORCH_OPS if max_ops is None else AUDIO_TOWER_TORCH_OPS[:max_ops]
        for step in selected_ops:
            _lower_audio_tower_op(rt, step, tensors=tensors, env=env)
    if max_ops == 0:
        return tensors.last_hidden_state
    if max_ops is None:
        return tensors.last_hidden_state
    last_step = selected_ops[-1]
    return _tensor(env, last_step.outputs[0])


def _audio_tower_env(tensors: GeneratedQwen3AsrAudioTowerTensors) -> dict[str, object]:
    return {
        field: getattr(tensors, field)
        for step in AUDIO_TOWER_TORCH_OPS
        for field in (*step.inputs, *step.outputs)
    }


def _audio_layer_env(
    layer_tensors: GeneratedQwen3AsrAudioEncoderLayerTensors,
    *,
    hidden_states: LogicalTensor,
    cu_seqlens: LogicalTensor,
) -> dict[str, object]:
    env: dict[str, object] = {
        field: getattr(layer_tensors, field)
        for step in AUDIO_ENCODER_LAYER_TORCH_OPS
        for field in (*step.inputs, *step.outputs)
        if hasattr(layer_tensors, field)
    }
    env["hidden_states"] = hidden_states
    env["cu_seqlens"] = cu_seqlens
    return env


def _tensor(env: dict[str, object], name: str) -> LogicalTensor:
    value = env[name]
    if not isinstance(value, LogicalTensor):
        raise TypeError(f"{name} must resolve to LogicalTensor, got {type(value).__name__}")
    return value


def _lower_audio_tower_op(
    rt: RuntimeSession,
    step: Qwen3ASRTorchOp,
    *,
    tensors: GeneratedQwen3AsrAudioTowerTensors,
    env: dict[str, object],
) -> None:
    if step.target == "aten.torch2vk.audio_encoder_layer_loop.default":
        hidden_states = _tensor(env, step.inputs[0])
        cu_seqlens = _tensor(env, step.inputs[1])
        for layer_tensors in tensors.layers:
            layer_env = _audio_layer_env(
                layer_tensors,
                hidden_states=hidden_states,
                cu_seqlens=cu_seqlens,
            )
            for layer_step in AUDIO_ENCODER_LAYER_TORCH_OPS:
                _lower_audio_layer_op(rt, layer_step, env=layer_env)
            hidden_states = layer_tensors.output
        env[step.outputs[0]] = hidden_states
        return

    shader = resolve_shader_symbol(op=step)
    if shader == "PAD_FEATURE_F32":
        PAD_FEATURE_F32(
            rt,
            input_features=_tensor(env, step.inputs[0]),
            feature_lens=_tensor(env, step.inputs[1]),
            output=_tensor(env, step.outputs[0]),
        )
    elif shader == "CONV2D_GELU_F32":
        CONV2D_GELU_F32(
            rt,
            x=_tensor(env, step.inputs[0]),
            weight=_tensor(env, step.inputs[1]),
            bias=_tensor(env, step.inputs[2]),
            output=_tensor(env, step.outputs[0]),
        )
    elif shader == "CONV_OUT_F32":
        CONV_OUT_F32(
            rt,
            x=_tensor(env, step.inputs[0]),
            weight=_tensor(env, step.inputs[1]),
            output=_tensor(env, step.outputs[0]),
        )
    elif shader == "ADD_POSITION_F32":
        ADD_POSITION_F32(
            rt,
            x=_tensor(env, step.inputs[0]),
            output=_tensor(env, step.outputs[0]),
        )
    elif shader == "COMPACT_AFTER_CNN_F32":
        COMPACT_AFTER_CNN_F32(
            rt,
            x=_tensor(env, step.inputs[0]),
            feature_lens=_tensor(env, step.inputs[1]),
            output=_tensor(env, step.outputs[0]),
        )
    elif shader == "CU_SEQLENS_U32":
        CU_SEQLENS_U32(
            rt,
            feature_lens=_tensor(env, step.inputs[0]),
            output=_tensor(env, step.outputs[0]),
        )
    elif shader == "LAYER_NORM_F32":
        LAYER_NORM_F32(
            rt,
            x=_tensor(env, step.inputs[0]),
            weight=_tensor(env, step.inputs[1]),
            bias=_tensor(env, step.inputs[2]),
            output=_tensor(env, step.outputs[0]),
        )
    elif shader == "LINEAR_GELU_F32":
        LINEAR_GELU_F32(
            rt,
            x=_tensor(env, step.inputs[0]),
            weight=_tensor(env, step.inputs[1]),
            bias=_tensor(env, step.inputs[2]),
            output=_tensor(env, step.outputs[0]),
        )
    elif shader == "LINEAR_F32":
        LINEAR_F32(
            rt,
            x=_tensor(env, step.inputs[0]),
            weight=_tensor(env, step.inputs[1]),
            bias=_tensor(env, step.inputs[2]),
            output=_tensor(env, step.outputs[0]),
        )
    else:
        raise NotImplementedError(f"Unsupported generated audio tower op: {step.target}")


def _lower_audio_layer_op(
    rt: RuntimeSession,
    step: Qwen3ASRTorchOp,
    *,
    env: dict[str, object],
) -> None:
    shader = resolve_shader_symbol(op=step)
    if shader == "LAYER_NORM_F32":
        LAYER_NORM_F32(
            rt,
            x=_tensor(env, step.inputs[0]),
            weight=_tensor(env, step.inputs[1]),
            bias=_tensor(env, step.inputs[2]),
            output=_tensor(env, step.outputs[0]),
        )
    elif shader == "LINEAR_F32":
        LINEAR_F32(
            rt,
            x=_tensor(env, step.inputs[0]),
            weight=_tensor(env, step.inputs[1]),
            bias=_tensor(env, step.inputs[2]),
            output=_tensor(env, step.outputs[0]),
        )
    elif shader == "ENCODER_ATTENTION_F32":
        ENCODER_ATTENTION_F32(
            rt,
            q=_tensor(env, step.inputs[0]),
            k=_tensor(env, step.inputs[1]),
            v=_tensor(env, step.inputs[2]),
            cu_seqlens=_tensor(env, step.inputs[3]),
            output=_tensor(env, step.outputs[0]),
        )
    elif shader == "ADD_F32":
        ADD_F32(
            rt,
            x=_tensor(env, step.inputs[0]),
            y=_tensor(env, step.inputs[1]),
            output=_tensor(env, step.outputs[0]),
        )
    elif shader == "LINEAR_GELU_F32":
        LINEAR_GELU_F32(
            rt,
            x=_tensor(env, step.inputs[0]),
            weight=_tensor(env, step.inputs[1]),
            bias=_tensor(env, step.inputs[2]),
            output=_tensor(env, step.outputs[0]),
        )
    else:
        raise NotImplementedError(f"Unsupported generated audio encoder layer op: {step.target}")
