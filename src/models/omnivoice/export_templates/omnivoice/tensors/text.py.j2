def declare_omnivoice_text_tensors(
    *,
    batch_size: int,
    prompt_length: int,
    max_sequence_length: int,
    hidden_size: int = {{ defaults.llm_hidden_size }},
    intermediate_size: int = {{ defaults.llm_intermediate_size }},
    vocab_size: int = {{ defaults.llm_vocab_size }},
    decoder_layers: int = {{ defaults.llm_num_hidden_layers }},
    num_attention_heads: int = {{ defaults.llm_num_attention_heads }},
    num_key_value_heads: int = {{ defaults.llm_num_key_value_heads }},
    head_dim: int = {{ defaults.llm_head_dim }},
    audio_vocab_size: int = {{ defaults.audio_vocab_size }},
    num_audio_codebook: int = {{ defaults.num_audio_codebook }},
) -> OmniVoiceTextTensors:
    prefill = _declare_omnivoice_text_prefill_tensors(
        prefix="omnivoice.prefill",
        batch_size=batch_size,
        sequence_length=prompt_length,
        hidden_size=hidden_size,
        vocab_size=vocab_size,
        audio_vocab_size=audio_vocab_size,
        num_audio_codebook=num_audio_codebook,
    )
    decode = _declare_omnivoice_text_decode_tensors(
        prefix="omnivoice.decode",
        batch_size=batch_size,
        sequence_length=1,
        max_sequence_length=max_sequence_length,
        hidden_size=hidden_size,
        vocab_size=vocab_size,
        audio_vocab_size=audio_vocab_size,
        num_audio_codebook=num_audio_codebook,
    )
    audio_head = OmniVoiceAudioHeadTensors(
        hidden_states=_activation(
            "omnivoice.audio_head.hidden_states",
            "float32",
            (batch_size, max_sequence_length, hidden_size),
        ),
        audio_heads_weight=_weight(
            "audio_heads.weight",
            "float32",
            (num_audio_codebook * audio_vocab_size, hidden_size),
        ),
        logits_flat=_activation(
            "omnivoice.audio_head.logits_flat",
            "float32",
            (batch_size, max_sequence_length, num_audio_codebook * audio_vocab_size),
        ),
        audio_logits_view=_activation(
            "omnivoice.audio_head.audio_logits_view",
            "float32",
            (batch_size, max_sequence_length, num_audio_codebook, audio_vocab_size),
        ),
        audio_logits=LogicalTensor(
            name="omnivoice.audio_head.audio_logits",
            spec=TensorSpec(
                dtype="float32",
                shape=(batch_size, num_audio_codebook, max_sequence_length, audio_vocab_size),
            ),
            role=TensorRole.OUTPUT,
            memory=MemoryClass.HOST_OUTPUT,
            lifetime=TensorLifetime.FRAME,
            semantic=TensorSemantic.LOGITS,
            compare=ComparePolicy(kind="tensor", rtol=3e-3, atol=3e-2),
        ),
    )
    return OmniVoiceTextTensors(
        prefill=prefill,
        decode=decode,
        audio_head=audio_head,
        token_select=_declare_omnivoice_token_select_tensors(
            batch_size=batch_size,
            sequence_length=max_sequence_length,
            audio_vocab_size=audio_vocab_size,
            num_audio_codebook=num_audio_codebook,
        ),
        training_loss=None,
    )


def _declare_omnivoice_text_prefill_tensors(
    *,
    prefix: str,
    batch_size: int,
    sequence_length: int,
    hidden_size: int,
    vocab_size: int,
    audio_vocab_size: int,
    num_audio_codebook: int,
) -> OmniVoiceTextPrefillTensors:
    common = _common_text_tensors(
        prefix=prefix,
        batch_size=batch_size,
        sequence_length=sequence_length,
        hidden_size=hidden_size,
        vocab_size=vocab_size,
        audio_vocab_size=audio_vocab_size,
        num_audio_codebook=num_audio_codebook,
    )
    return OmniVoiceTextPrefillTensors(**common)


